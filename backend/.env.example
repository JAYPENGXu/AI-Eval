SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5174

# Reuse the same OpenAI-compatible settings style as AIFriends.
API_KEY=your_api_key_here
API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key_here

CHAT_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
RAG_TOP_K=5

# Session summary memory
SESSION_SUMMARY_ENABLED=true
SESSION_SUMMARY_TRIGGER_MESSAGES=12
SESSION_SUMMARY_MAX_CHARS=2000
SESSION_SUMMARY_NEW_MESSAGES_LIMIT=40
SESSION_SUMMARY_MODEL=


# Document parsing and OCR
DOCUMENT_MAX_UPLOAD_BYTES=52428800
DOCUMENT_MAX_PDF_PAGES=300
DOCUMENT_MAX_DOCX_UNCOMPRESSED_BYTES=209715200
DOCUMENT_REVIEW_MIN_COVERAGE=0.90
DOCUMENT_REVIEW_MAX_BLANK_RATE=0.10
DOCUMENT_REVIEW_MAX_GARBLED_RATE=0.02
PDF_NATIVE_TEXT_MIN_CHARS=40
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_TOKEN=your_paddleocr_token_here
PADDLEOCR_MODEL=PaddleOCR-VL-1.6
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Dedicated Milvus Lite gRPC server (shared by Django and Celery)
VECTOR_STORE=milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=aiassistant_chunks
